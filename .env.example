NODE_ENV=production
API_PORT=3001
API_HOST=0.0.0.0
APP_PUBLIC_URL=https://api.example.com
WEB_PUBLIC_URL=https://app.example.com
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
